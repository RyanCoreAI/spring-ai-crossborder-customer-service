# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=omni_merchant
MYSQL_USER=omnimerchant
MYSQL_ROOT_PASSWORD=
MYSQL_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# PostgreSQL (PGVector)
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=omni_merchant
PG_USER=omnimerchant
PG_PASSWORD=

# RocketMQ
ROCKETMQ_NAMESRV=localhost:9876
ROCKETMQ_NAMESRV_PORT=9876
ROCKETMQ_BROKER_FAST_PORT=10909
ROCKETMQ_BROKER_PORT=10911
ROCKETMQ_DASHBOARD_PORT=18080

# AI provider keys are optional for the local business demo.
# Keep model switches as "none" when keys are not configured.
SPRING_AI_MODEL_CHAT=none
SPRING_AI_MODEL_EMBEDDING=none
SPRING_AI_MODEL_AUDIO_SPEECH=none
SPRING_AI_MODEL_AUDIO_TRANSCRIPTION=none
SPRING_AI_MODEL_IMAGE=none
SPRING_AI_MODEL_MODERATION=none
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# Admin auth (must be set before starting the app)
ADMIN_EMAIL=
ADMIN_PASSWORD=
JWT_SECRET=
JWT_EXPIRATION_MS=86400000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5188,http://127.0.0.1:5188

# Base64 AES key for encrypted Shopify/custom app credentials.
# Example generator: openssl rand -base64 32
INTEGRATION_ENCRYPTION_KEY=

# Optional Druid monitor (disabled by default)
DRUID_STAT_ENABLED=false
DRUID_LOGIN_USERNAME=
DRUID_LOGIN_PASSWORD=

# v2 optional Shopify OAuth / observability
APP_BASE_URL=http://localhost:8090
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_SCOPES=read_products,read_customers,read_orders,read_fulfillments
EVAL_LIVE_AGENT_ENABLED=false
RAG_SAFETY_STRICT=true
OTEL_TRACING_SAMPLER=always-off
OTEL_TRACING_SAMPLE_RATE=0.0
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
OTEL_METRICS_EXPORT_ENABLED=false
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://localhost:4318/v1/metrics
OBSERVABILITY_PROMPT_LOGGING=false

# Optional Maven mirror used only by the Docker builder. Leave Central globally;
# users behind a restricted network can set a trusted mirror explicitly.
MAVEN_REPOSITORY_URL=https://repo.maven.apache.org/maven2
